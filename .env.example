# OFMS Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL="postgresql://username:password@localhost:5432/ofms_database"

# Optional: Separate databases for migration/testing
SOURCE_DATABASE_URL="postgresql://username:password@localhost:5432/source_db"
TARGET_DATABASE_URL="postgresql://username:password@localhost:5432/target_db"

# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3005"

# ============================================
# MOBILE (Capacitor iOS / Android)
# ============================================
# URL the native shell loads. Use your machine LAN IP for physical devices during dev
# (e.g. http://192.168.1.42:3005). Production builds should use your deployed HTTPS URL.
CAPACITOR_SERVER_URL="http://localhost:3005"

# ============================================
# AI / PLANT VISION
# ============================================
# Local Ollama (preferred for on-prem vision)
OLLAMA_BASE_URL="http://localhost:11434"
# Optional — OFMS auto-resolves to installed tags when exact name is missing
OLLAMA_VISION_MODEL="qwen3:latest"
OLLAMA_REASONING_MODEL="deepseek-r1:latest"
OLLAMA_TEXT_MODEL="qwen3:32b"

# Cloud vision fallback for Plant Vision Scan
OPENAI_API_KEY=""

# ============================================
# TEST/AUTOMATION CREDENTIALS
# ============================================
# Used for automated testing and demo data
# CHANGE THESE IN PRODUCTION!
TEST_ADMIN_EMAIL="admin@example.com"
TEST_ADMIN_PASSWORD="change_me_in_production"
TEST_MANAGER_EMAIL="manager@example.com"
TEST_MANAGER_PASSWORD="change_me_in_production"
TEST_WORKER_EMAIL="worker@example.com"
TEST_WORKER_PASSWORD="change_me_in_production"

# Showcase demo farm owner passwords (used only when creating new showcase users)
SHOWCASE_CURRY_PASSWORD="change_me_in_production"
SHOWCASE_DEMO_PASSWORD="change_me_in_production"

# ============================================
# SECURITY NOTES
# ============================================
# 1. NEVER commit the .env file to git
# 2. Use strong, unique passwords in production
# 3. Rotate credentials regularly
# 4. Use different credentials for each environment
# 5. Consider using a secrets manager for production
